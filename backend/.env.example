APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

REALTIME_PROVIDER=gemini
SPEECH_PIPELINE=realtime
REALTIME_VIDEO_FPS=10
PROCESSOR_FPS=10
ENABLE_FACE_DROOP_PROCESSOR=false
ENABLE_POSE_PROCESSOR=true
POSE_MODEL_PATH=yolo11n-pose.pt
POSE_CONF_THRESHOLD=0.5
POSE_DEVICE=cpu
POSE_ENABLE_HAND_TRACKING=true
GEMINI_LLM_MODEL=gemini-3-flash-preview
FAST_WHISPER_MODEL_SIZE=base
FAST_WHISPER_LANGUAGE=en
FAST_WHISPER_DEVICE=cpu
PIPELINE_TURN_DELAY_MS=1200
BACKEND_TTS_ENABLED=true

AGENT_NAME=DroopDetection Agent
AGENT_USER_ID=agent
AGENT_INSTRUCTIONS=You are a guidance-only first-aid assistant. Use visible evidence, processor signals, and retrieved guidance to help the wearer assess urgent situations. Never pretend to place calls or take external actions on the user's behalf.

# Vision Agents typically expects provider credentials and Stream credentials in env.
# Fill these in when you wire the realtime backend for real sessions.
STREAM_API_KEY=
STREAM_API_SECRET=
OPENAI_API_KEY=
GEMINI_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=VR6AewLTigWG4xSOukaG
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
